<%= form_with(model: game_event, class: "contents") do |form| %>
  <% if game_event.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(game_event.errors.count, "error") %> prohibited this game_event from being saved:</h2>

      <ul class="list-disc ml-6">
        <% game_event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :minute %>
    <%= form.number_field :minute, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": game_event.errors[:minute].none?, "border-red-400 focus:outline-red-600": game_event.errors[:minute].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :description %>
    <%= form.textarea :description, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": game_event.errors[:description].none?, "border-red-400 focus:outline-red-600": game_event.errors[:description].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :game_id %>
    <%= form.text_field :game_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": game_event.errors[:game_id].none?, "border-red-400 focus:outline-red-600": game_event.errors[:game_id].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
