<div id="<%= dom_id game %>" class="card bg-base-100 shadow-md hover:shadow-lg card-hover">
  <div class="card-body">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h3 class="card-title text-xl">⚽ Partida #<%= game.id %></h3>
        <div class="flex items-center gap-2 mt-1">
          <div class="badge badge-outline">
            <%= game.players.count %>/2 jogadores
          </div>
          <div class="badge <%= game.status == 'aguardando' ? 'badge-warning' : game.status == 'sala_cheia' ? 'badge-info' : 'badge-success' %>">
            <%= game.status.humanize %>
          </div>
        </div>
      </div>
      
      <!-- Status visual -->
      <div class="flex -space-x-2">
        <% game.players.each_with_index do |player, index| %>
          <div class="avatar placeholder">
            <div class="bg-primary text-primary-content rounded-full w-8 h-8">
              <span class="text-xs"><%= player.player_number || index + 1 %></span>
            </div>
          </div>
        <% end %>
        <% (2 - game.players.count).times do |i| %>
          <div class="avatar placeholder">
            <div class="bg-base-300 text-base-content rounded-full w-8 h-8">
              <span class="text-xs">?</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Informações dos jogadores -->
    <% if game.players.any? %>
      <div class="space-y-2 mb-4">
        <% game.players.order(:player_number).each do |player| %>
          <div class="flex items-center gap-2 text-sm">
            <div class="w-2 h-2 bg-primary rounded-full"></div>
            <span class="font-medium">Jogador <%= player.player_number %>:</span>
            <span><%= player.name %></span>
            <% if player.ready? %>
              <div class="badge badge-success badge-xs">Pronto</div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Ações -->
    <div class="card-actions justify-end">
      <% if game.players.count < 2 %>
        <%= button_to join_game_path(game), { method: :post }, { class: "btn btn-primary" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
          </svg>
          Entrar
        <% end %>
      <% else %>
        <button class="btn btn-disabled">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          Sala Cheia
        </button>
      <% end %>
      
      <!-- Link para assistir se a partida estiver em andamento -->
      <% if game.status == "em_andamento" %>
        <%= link_to "Assistir", game_path(game), class: "btn btn-outline btn-sm" %>
      <% end %>
    </div>
  </div>
</div>