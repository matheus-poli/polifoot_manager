<% if game.status == "em_andamento" %>
  <%# --- TELA DA PARTIDA EM ANDAMENTO --- %>
  <div id="match_screen" class="space-y-6">
    <!-- Header da partida -->
    <div class="text-center">
      <div class="badge badge-success badge-lg mb-2">Partida em Andamento</div>
      <h1 class="text-2xl lg:text-4xl font-bold text-base-content">⚽ Partida #<%= game.id %></h1>
    </div>
    
    <%# Placar %>
    <%= render 'games/scoreboard', game: game %>

    <%# Log de Eventos %>
    <div class="card bg-base-100 shadow-lg">
      <div class="card-header">
        <h2 class="card-title">📝 Eventos da Partida</h2>
      </div>
      <div class="card-body p-0">
        <div id="game_events" class="h-96 overflow-y-auto bg-base-200/50">
          <% if game.game_events.any? %>
            <%= render game.game_events.order(:minute) %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

<% else %>
  <%# --- TELA DE PREPARAÇÃO (SALA) --- %>
  <div id="lobby_screen" class="space-y-6">
    <!-- Header da sala -->
    <div class="text-center">
      <div class="badge badge-warning badge-lg mb-2">Preparação</div>
      <h1 class="text-2xl lg:text-4xl font-bold text-base-content">🎮 Sala da Partida #<%= game.id %></h1>
      <p class="text-base-content/70 mt-2">Status: 
        <span class="badge <%= game.status == 'aguardando' ? 'badge-warning' : game.status == 'sala_cheia' ? 'badge-info' : 'badge-success' %>">
          <%= game.status.humanize %>
        </span>
      </p>
    </div>

    <!-- Instruções -->
    <div class="alert alert-info">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <div>
        <h3 class="font-bold">Como jogar:</h3>
        <div class="text-sm">
          1. Personalize seu nome • 2. Escolha sua tática • 3. Clique em "Estou Pronto" • 4. Aguarde o oponente
        </div>
      </div>
    </div>

    <!-- Grid dos jogadores -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <%= render game.players.order(:player_number) %>
      
      <!-- Slot vazio se necessário -->
      <% if game.players.count < 2 %>
        <div class="card bg-base-200 border-2 border-dashed border-base-300">
          <div class="card-body items-center justify-center text-center py-12">
            <div class="text-4xl mb-4 opacity-50">👤</div>
            <h3 class="text-xl font-bold text-base-content/60">Aguardando Jogador</h3>
            <p class="text-base-content/50 mt-2">
              Compartilhe o link da partida ou aguarde alguém entrar pelo lobby
            </p>
            <div class="mt-4">
              <div class="badge badge-outline">Slot <%= game.players.count + 1 %> vazio</div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
