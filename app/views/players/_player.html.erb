<div id="<%= dom_id(player) %>" class="bg-white p-6 rounded-lg shadow-md">
  <h2 class="font-bold text-2xl mb-4 text-center">Jogador <%= player.player_number || 'N/A' %></h2>
  <p class="text-center text-lg mb-2"><strong>Time:</strong> <%= player.team_name %></p>
  <p class="text-center text-lg mb-6"><strong>Nome:</strong> <%= player.name %></p>

  <% if current_player == player && !player.ready? %>
    <!-- Formulário para alterar nome -->
    <%= form_with(model: player, url: player_path(player), method: :patch, local: true, class: "mb-4") do |form| %>
      <div class="mb-4">
        <%= form.label :name, "Seu Nome", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :name, class: "w-full rounded-md border-gray-300 shadow-sm" %>
      </div>
      
      <div class="text-center mb-4">
        <%= form.submit "Atualizar Nome", class: "w-full rounded-md px-5 py-3 bg-gray-600 hover:bg-gray-500 text-white font-medium cursor-pointer" %>
      </div>
    <% end %>

    <!-- Formulário para escolher tática e dar ready -->
    <%= form_with(model: player, url: player_path(player), method: :patch) do |form| %>
      <div class="mb-4">
        <%= form.label :tactic, "Mentalidade Tática", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :tactic, ["Balanceada", "Agressiva", "Defensiva"], {}, class: "w-full rounded-md border-gray-300 shadow-sm" %>
      </div>

      <%= form.hidden_field :ready, value: "true" %>
      <div class="text-center">
        <%= form.submit "Estou Pronto", class: "w-full rounded-md px-5 py-3 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center p-4 border-dashed border-2 border-gray-300 rounded-md h-32 flex flex-col justify-center">
        <p class="text-gray-600 font-semibold">Tática Escolhida:</p>
        <p class="text-xl"><%= player.tactic %></p>
    </div>
  <% end %>

  <div class="mt-4 text-center">
    <p class="font-semibold">Status: <%= player.ready? ? 'Pronto' : 'Aguardando' %></p>
  </div>
</div>