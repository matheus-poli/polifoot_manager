<div id="<%= dom_id(player) %>" class="card bg-base-100 shadow-lg border <%= current_player == player ? 'ring-2 ring-primary ring-offset-2' : '' %>">
  <div class="card-body">
    <!-- Header do jogador -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <div class="avatar placeholder">
          <div class="bg-primary text-primary-content rounded-full w-12 h-12">
            <span class="text-xl font-bold"><%= player.player_number || '?' %></span>
          </div>
        </div>
        <div>
          <h3 class="card-title text-lg">Jogador <%= player.player_number || 'N/A' %></h3>
          <div class="badge badge-sm <%= player.ready? ? 'badge-success' : 'badge-warning' %>">
            <%= player.ready? ? '✓ Pronto' : '⏳ Preparando' %>
          </div>
        </div>
      </div>
      <% if current_player == player %>
        <div class="badge badge-primary">Você</div>
      <% end %>
    </div>

    <!-- Informações do time -->
    <div class="bg-base-200 rounded-lg p-4 mb-4">
      <div class="grid grid-cols-1 gap-2">
        <div>
          <span class="text-sm font-medium text-base-content/70">Time:</span>
          <p class="font-semibold"><%= player.team_name %></p>
        </div>
        <div>
          <span class="text-sm font-medium text-base-content/70">Técnico:</span>
          <p class="font-semibold"><%= player.name %></p>
        </div>
        <div>
          <span class="text-sm font-medium text-base-content/70">Tática:</span>
          <div class="badge <%= player.tactic == 'Agressiva' ? 'badge-error' : player.tactic == 'Defensiva' ? 'badge-info' : 'badge-warning' %>">
            <%= player.tactic %>
          </div>
        </div>
      </div>
    </div>

    <% if current_player == player && !player.ready? %>
      <!-- Formulário para alterar nome -->
      <div class="mb-4">
        <div class="collapse collapse-arrow bg-base-200">
          <input type="checkbox" /> 
          <div class="collapse-title text-sm font-medium">
            <span class="text-lg">✏️</span> Personalizar Nome
          </div>
          <div class="collapse-content">
            <%= form_with(model: player, url: player_path(player), method: :patch, local: true) do |form| %>
              <div class="form-control mb-4">
                <%= form.label :name, class: "label" do %>
                  <span class="label-text">Como você quer ser chamado?</span>
                <% end %>
                <%= form.text_field :name, class: "input input-bordered w-full", placeholder: "Digite seu nome" %>
              </div>
              
              <div class="form-control">
                <%= form.submit "Salvar Nome", class: "btn btn-outline btn-sm" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Formulário para escolher tática e dar ready -->
      <%= form_with(model: player, url: player_path(player), method: :patch) do |form| %>
        <div class="form-control mb-6">
          <%= form.label :tactic, class: "label" do %>
            <span class="label-text font-medium">
              <span class="text-lg">⚽</span> Escolha sua Tática
            </span>
          <% end %>
          <%= form.select :tactic, [
            ['🛡️ Defensiva', 'Defensiva'], 
            ['⚖️ Balanceada', 'Balanceada'], 
            ['⚔️ Agressiva', 'Agressiva']
          ], {}, { class: "select select-bordered w-full" } %>
          <div class="label">
            <span class="label-text-alt">A tática afeta o desempenho do seu time</span>
          </div>
        </div>

        <%= form.hidden_field :ready, value: "true" %>
        <div class="form-control">
          <%= form.submit "🚀 Estou Pronto!", class: "btn btn-primary btn-lg w-full" %>
        </div>
      <% end %>
    <% else %>
      <!-- Estado quando pronto ou não é o jogador atual -->
      <div class="text-center py-8">
        <% if player.ready? %>
          <div class="text-4xl mb-2">✅</div>
          <p class="font-bold text-lg text-success">Jogador Pronto!</p>
          <p class="text-sm text-base-content/70">Aguardando outros jogadores...</p>
        <% else %>
          <div class="text-4xl mb-2">⏳</div>
          <p class="font-bold text-lg">Preparando...</p>
          <p class="text-sm text-base-content/70">O jogador está configurando sua tática</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>